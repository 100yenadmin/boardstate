{
  "name": "@boardstate/lit",
  "version": "0.7.0",
  "description": "The Boardstate reference view — <boardstate-view> and 15 builtin widgets as custom elements",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/100yenadmin/boardstate#readme",
  "bugs": "https://github.com/100yenadmin/boardstate/issues",
  "keywords": [
    "dashboard",
    "agent",
    "ai",
    "mcp",
    "widgets",
    "layout-as-data",
    "generative-ui",
    "lit",
    "boardstate"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./styles.css": "./src/styles/boardstate.css",
    "./themes/aurora.css": "./src/styles/themes/aurora.css",
    "./themes/vibrancy.css": "./src/styles/themes/vibrancy.css",
    "./locales/*": {
      "types": "./dist/locales/*.d.ts",
      "import": "./dist/locales/*.js"
    }
  },
  "files": [
    "dist",
    "src/styles/boardstate.css",
    "src/styles/themes",
    "THEME.md"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run"
  },
  "dependencies": {
    "@boardstate/schema": "workspace:*",
    "@boardstate/core": "workspace:*",
    "@boardstate/host": "workspace:*"
  },
  "peerDependencies": {
    "lit": "^3.3.0"
  },
  "devDependencies": {
    "lit": "3.3.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/100yenadmin/boardstate.git",
    "directory": "packages/lit"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
